# ============================================================================
# Kitora · Environment Variables
# Copy this file to `.env` for local development.
# Both Next.js and Prisma read `.env` natively, so a single file is enough.
# ============================================================================

# --- Application -------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kitora"

# --- Database ----------------------------------------------------------------
# Postgres connection string. For Vercel Postgres / Supabase / Neon, use the
# pooled URL here and the direct URL in DIRECT_URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kitora?schema=public"
# DIRECT_URL=""

# --- Auth.js (NextAuth v5) ---------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# AUTH_URL="http://localhost:3000"  # only required when not using Vercel

# OAuth providers (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_TEAM_PRICE_ID="price_..."

# --- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY="re_..."
EMAIL_FROM="Kitora <onboarding@yourdomain.com>"

# --- Rate limiting (Upstash Redis) -------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Observability -----------------------------------------------------------
LOG_LEVEL="info"
NEXT_PUBLIC_ANALYTICS_ID=""

# --- CI/build ----------------------------------------------------------------
# Set to 1 in CI when env vars aren't available (e.g. type-check only steps).
# SKIP_ENV_VALIDATION=1
