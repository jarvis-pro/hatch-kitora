# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# ============================================================================
# Kitora · .gitignore
# ============================================================================

# ---- Dependencies -----------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# pnpm
.pnpm-store/
.pnpm-debug.log*

# pnpm probe / cleanup leftovers (created when pnpm tests hard-link support)
_tmp_*

# ---- Build output -----------------------------------------------------------
/.next/
/out/
/build
/dist
.swc/
*.tsbuildinfo
next-env.d.ts

# Turbo / Nx caches
.turbo/
.nx/cache/

# ---- Test & coverage --------------------------------------------------------
/coverage
/.nyc_output
/playwright-report
/test-results
/cypress/videos
/cypress/screenshots
/cypress/downloads

# ---- Logs -------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ---- Local env files --------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Keep:
!.env.example

# ---- Deploy / hosting -------------------------------------------------------
.vercel
.netlify
.wrangler/

# ---- Prisma -----------------------------------------------------------------
# Local SQLite for prisma migrate dev (if used)
/prisma/migrations/dev.db*
/prisma/.db
# Generated client (regenerated via `prisma generate`)
/prisma/generated
.prisma/

# ---- Email (React Email dev server) ----------------------------------------
.react-email/

# ---- Stripe CLI -------------------------------------------------------------
.stripe/

# ---- Sentry -----------------------------------------------------------------
.sentryclirc

# ---- Storybook --------------------------------------------------------------
storybook-static/

# ---- Husky (only ignore internal _ dir; keep hook scripts tracked) ---------
.husky/_

# ---- Editors / IDEs ---------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# JetBrains
*.iml

# ---- OS ---------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Misc -------------------------------------------------------------------
*.pem
*.local
.tmp/
tmp/
