# 更多关于 .gitignore 的说明：https://help.github.com/articles/ignoring-files/
# ============================================================================
# Kitora · .gitignore
# ============================================================================

# ---- 依赖 -------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# pnpm
.pnpm-store/
.pnpm-debug.log*

# pnpm 探测硬链接支持时产生的临时文件
_tmp_*

# ---- 构建产物 ---------------------------------------------------------------
/.next/
/out/
/build
/dist
.swc/
*.tsbuildinfo
next-env.d.ts

# Turbo / Nx 缓存
.turbo/
.nx/cache/

# ---- 测试与覆盖率 -----------------------------------------------------------
/coverage
/.nyc_output
/playwright-report
/test-results
/cypress/videos
/cypress/screenshots
/cypress/downloads

# ---- 日志 -------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ---- 本地环境变量 -----------------------------------------------------------
# `.env` 已提交 —— 仅存放非 secret 的默认值，clone 后开箱即用。
# 真实 secret 必须放在 `.env.local`（已 gitignored）
# 或生产部署平台（Vercel / Fly / Railway）的环境变量面板里。
.env.local
.env.*.local
# 特定环境的提交文件如果只含非 secret 信息也可以跟踪；
# 默认忽略是保守处理：
.env.production
.env.test

# ---- 部署 / 托管 ------------------------------------------------------------
.vercel
.netlify
.wrangler/

# ---- Prisma -----------------------------------------------------------------
# prisma migrate dev 使用的本地 SQLite（如有）
/prisma/migrations/dev.db*
/prisma/.db
# 生成的客户端（通过 `prisma generate` 重建）
/prisma/generated
.prisma/

# ---- Email（React Email 开发服务器）----------------------------------------
.react-email/

# ---- Stripe CLI -------------------------------------------------------------
.stripe/

# ---- Sentry -----------------------------------------------------------------
.sentryclirc

# ---- Storybook --------------------------------------------------------------
storybook-static/

# ---- Husky（只忽略内部 _ 目录，hook 脚本本身保持跟踪）--------------------
.husky/_

# ---- 编辑器 / IDE -----------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
*.code-workspace

# JetBrains
*.iml

# Claude Code（每个开发者自己的覆盖配置；项目级 settings.json 已提交）
.claude/settings.local.json

# ---- 操作系统 ---------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- 其他 -------------------------------------------------------------------
*.pem
*.local
.tmp/
tmp/
