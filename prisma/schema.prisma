// Prisma schema for Kitora
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Uncomment when deploying behind a connection pooler (Supabase / Neon /
  // Vercel Postgres) — `url` then points at the pooled connection, while
  // `directUrl` is used by `prisma migrate` and introspection.
  // directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// RFC 0005 — Multi-region (data residency)
// ---------------------------------------------------------------------------
//
// Every tenant-scoped row carries a `region`, set at insert time from the
// process-wide `KITORA_REGION` env var (resolved through `currentRegion()`
// in `src/lib/region.ts`). Region is *not* a runtime variable: a Kitora
// stack runs in exactly one region for its lifetime. The column exists so
// (a) a single migration can carry historical rows forward (`GLOBAL`
// backfill) without code branches, and (b) ad-hoc admin / forensic queries
// run against the canonical column rather than guessing from the
// connection URL.
//
//   GLOBAL   non-CN, non-EU stack — kitora.io (the only region v0.6 ships).
//   CN       mainland China stack — kitora.cn (RFC 0006 lights this up).
//   EU       EU residency stack — kitora.eu (placeholder, no timeline).
//
// Cross-region calls are HTTP-only (think outbound webhooks). There is no
// shared database between regions; the column is metadata, not a sharding
// hint.
enum Region {
  GLOBAL
  CN
  EU
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) — required tables
// ---------------------------------------------------------------------------

model User {
  id                      String     @id @default(cuid())
  name                    String?
  email                   String
  emailVerified           DateTime?
  image                   String?
  passwordHash            String? // for credentials provider
  role                    UserRole   @default(USER)
  locale                  String     @default("en")
  // Bumped whenever the user wants to invalidate every issued JWT (password
  // change, "sign out everywhere", account deletion). Compared inside the
  // jwt callback — mismatch forces the holder to sign in again.
  sessionVersion          Int        @default(0)
  // RFC 0002 PR-2 — denormalized flag so jwt callback / wall checks don't
  // join TwoFactorSecret on every request. Flipped in the same tx as the
  // TwoFactorSecret.enabledAt write; truthy iff a confirmed TOTP secret exists.
  twoFactorEnabled        Boolean    @default(false)
  // RFC 0002 PR-4 — account deletion grace period. Users in PENDING_DELETION
  // can only access /settings/account/* (cancel path); cron runs daily,
  // hard-deletes anyone past `deletionScheduledAt`.
  status                  UserStatus @default(ACTIVE)
  deletionScheduledAt     DateTime?
  deletionRequestedFromIp String?
  // RFC 0005 — Region the user account lives in. Stamped on insert from
  // `currentRegion()`; immutable thereafter. Same email may exist in two
  // regions (e.g. `alice@acme.com` in GLOBAL and again in CN) and they
  // are independent accounts — see the `(email, region)` composite unique.
  region                  Region     @default(GLOBAL)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  accounts        Account[]
  sessions        Session[]
  apiTokens       ApiToken[]
  memberships     Membership[]
  deviceSessions  DeviceSession[]
  twoFactorSecret TwoFactorSecret?

  // RFC 0005 — composite unique replaces the historical `email @unique`.
  // Inside one stack the live region is fixed, so all lookups still hit
  // by email; the `region` column is required to keep cross-region
  // imports / disaster recovery dumps coherent.
  @@unique([email, region])
  // RFC 0002 PR-4 — supports the daily deletion cron's hot path.
  @@index([status, deletionScheduledAt])
  @@index([region])
}

enum UserRole {
  USER
  ADMIN
}

// RFC 0002 PR-4 — account lifecycle states.
//
// ACTIVE             — normal operation.
// PENDING_DELETION   — user has requested deletion; `deletionScheduledAt`
//                      is set 30 days in the future. Login is still
//                      allowed (so they can cancel), but every request
//                      is wallpapered into /settings/account by middleware.
//
// Hard-delete (the row + all cascading data) happens via the daily cron
// in `scripts/run-deletion-cron.ts`. AuditLog rows survive because they
// already store actorId without a FK.

enum UserStatus {
  ACTIVE
  PENDING_DELETION
}

// ---------------------------------------------------------------------------
// Organizations — 多租户主体（参见 docs/rfcs/0001-organizations.md）
// ---------------------------------------------------------------------------
//
// 每个用户注册自动创建一个 Personal Org（slug = personal-{shortId}），用户
// 为 OWNER。所有 org-scoped 资源（Subscription / ApiToken / AuditLog）以
// orgId 归属。PR-1 仅引入新表与 nullable orgId 列，旧字段保留以便回滚。

model Organization {
  id               String   @id @default(cuid())
  slug             String   @unique // URL-safe lowercase, e.g. "acme" / "personal-abcd1234"
  name             String
  image            String?
  // Stripe customer 归属在 Org 上 —— PR-4 后这是唯一来源
  stripeCustomerId String?  @unique
  // RFC 0005 占位字段：per-org ICP 备案号；PR-1 仅加列，业务逻辑后续 RFC 实现
  icpNumber        String?
  // RFC 0005 — region the org was created in. Immutable: enforced at the
  // server-action layer (`updateOrgAction` rejects any change). Stamped
  // from `currentRegion()` at create time; v0.6 backfill set every legacy
  // row to GLOBAL.
  region           Region   @default(GLOBAL)
  // RFC 0002 PR-4 — when true, every member of this org must have 2FA
  // enabled. `assertOrg2faCompliance()` enforces this at every server
  // action / RSC entrypoint that resolves an active org. Toggle via
  // `toggleOrgRequire2faAction` (OWNER + caller has 2FA themselves).
  require2fa       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships       Membership[]
  invitations       Invitation[]
  subscriptions     Subscription[]
  apiTokens         ApiToken[]
  webhookEndpoints  WebhookEndpoint[]
  identityProviders IdentityProvider[]

  @@index([slug])
  @@index([region])
}

model Membership {
  id       String   @id @default(cuid())
  orgId    String
  userId   String
  role     OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  // RFC 0004 — SSO. Set on JIT-provisioned members so the next SAML/OIDC
  // login can resolve back to this row even if the user's email rotates
  // (NameID / OIDC sub stays stable across that). Both null for legacy
  // (password / OAuth) members.
  providerId      String?
  providerSubject String?

  // RFC 0004 — SCIM PATCH `active: false` is "deactivate, may reactivate";
  // we soft-delete here rather than removing the row so a follow-up
  // `active: true` can resurrect membership without a DB-level recreate.
  // SCIM DELETE / manual remove paths still hard-delete.
  deletedAt DateTime?

  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  identityProvider IdentityProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([providerId, providerSubject])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// 邀请：raw token 随邮件发出，库内只存 sha256(token)。同一 org + email
// 仅允许一条 pending 记录（接受 / 撤销后该约束不再阻止重新邀请，因为
// acceptedAt / revokedAt 标记会与 unique 上的过滤一起在应用层处理）。

model Invitation {
  id         String    @id @default(cuid())
  orgId      String
  email      String
  role       OrgRole
  tokenHash  String    @unique
  expiresAt  DateTime
  // 邀请人 userId — no FK，邀请人删号也保留这条记录用于审计
  invitedBy  String
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([email])
  @@index([expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Device sessions — per-JWT revocable session record (RFC 0002 PR-1)
// ---------------------------------------------------------------------------
//
// Each issued JWT carries a `sid` claim (random base64url, 32 bytes). The
// hash lands here so we can revoke any single session without nuking the
// global `User.sessionVersion`. The jwt() callback in `src/lib/auth/index.ts`
// re-validates the row on every call — missing or `revokedAt != null` ⇒ the
// JWT is rejected and the holder is forced to re-login.
//
// `lastSeenAt` is updated with a 60s throttle (see `touchDeviceSession`) so
// this row never becomes a write hot-spot under heavy traffic.

model DeviceSession {
  id         String    @id @default(cuid())
  userId     String
  // sha256(sid) — the raw sid only ever lives inside the signed JWT.
  sidHash    String    @unique
  // Raw User-Agent string captured at sign-in. UI parses for display.
  userAgent  String?
  // Approximate IP at sign-in time; not updated afterwards (see RFC 0002 §6).
  ip         String?
  lastSeenAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hot path: list a user's active sessions. With (userId, revokedAt) the
  // common `revokedAt IS NULL` filter is also covered.
  @@index([userId, revokedAt])
  @@index([lastSeenAt])
}

// ---------------------------------------------------------------------------
// Two-factor — TOTP secret + one-time backup codes (RFC 0002 PR-2)
// ---------------------------------------------------------------------------
//
// `encSecret` holds the TOTP shared secret, encrypted with AES-256-GCM whose
// key is HKDF-derived from `AUTH_SECRET` + `userId` (so a single-row leak
// can't decrypt the rest of the table without the master secret). The IV +
// auth tag are prepended to the ciphertext — the lib in `src/lib/auth/2fa-
// crypto.ts` is the only thing that should touch this column.
//
// `backupHashes` are sha256 of single-use codes; we delete on use rather
// than mark "used" so an attacker who reads the row can't tell how many
// remain. Regenerating wipes the array and re-issues 10 fresh codes.
//
// `enabledAt = null` is the half-enrolled state — the user has scanned the
// QR but hasn't yet confirmed a TOTP code. The `User.twoFactorEnabled`
// boolean is the source of truth for "fully active".

// ---------------------------------------------------------------------------
// Outbound webhooks (RFC 0003)
// ---------------------------------------------------------------------------
//
// Per-org `WebhookEndpoint` rows are the user-facing "subscriptions": URL,
// list of event types they care about, and an HMAC secret they keep on
// their side. Every fired event spawns N `WebhookDelivery` rows (one per
// matching endpoint) — the cron in `scripts/run-webhook-cron.ts` (PR-2)
// picks them up and POSTs.
//
// Secrets are never stored in the clear: only `secretHash = sha256(raw)`.
// `secretPrefix` is a short user-facing fingerprint so endpoints can be
// disambiguated in the UI without exposing the hash.

model WebhookEndpoint {
  id                  String    @id @default(cuid())
  orgId               String
  url                 String
  description         String?
  // Whitelist of event names this endpoint wants to receive. Empty array
  // ⇒ no events fire (effectively a soft-pause). See `WEBHOOK_EVENTS` in
  // src/lib/webhooks/enqueue.ts for the canonical list.
  enabledEvents       String[]  @db.Text
  secretHash          String
  // base64url(8 bytes) — shown to the user, safe to leak.
  secretPrefix        String
  // RFC 0003 PR-2 — AES-256-GCM-encrypted plaintext secret. Key is HKDF-
  // derived from `AUTH_SECRET` + endpoint id (same recipe as 2FA secrets).
  // Nullable for backwards-compat with rows created in PR-1; PR-2's create
  // and rotate paths always fill it. The cron decrypts before signing.
  encSecret           Bytes?
  // Hard pause — `disabledAt = now()` halts deliveries entirely. Set by
  // user action OR auto by PR-4 sweeper after `consecutiveFailures >= 8`.
  disabledAt          DateTime?
  // Counter only the cron mutates: incremented on RETRYING/DEAD_LETTER,
  // reset on DELIVERED. Defends against UI showing stale state vs cron.
  consecutiveFailures Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([orgId])
  @@index([disabledAt])
}

// One row per (event × endpoint) attempt-set. Retries flip `attempt` and
// `nextAttemptAt` in place rather than spawning new rows — keeps history
// linear and the index hot path lean. PR-4 sweeps DELIVERED / DEAD_LETTER
// / CANCELED rows after 30 days.

model WebhookDelivery {
  id             String                @id @default(cuid())
  endpointId     String
  // Logical event id — the same value across every retry of this row, and
  // mirrored to the receiver via the `X-Kitora-Event-Id` header so they
  // can dedupe.
  eventId        String
  eventType      String
  // Frozen full event payload — UI Resend just re-POSTs this body, no
  // re-fetch from the source needed.
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempt        Int                   @default(0)
  nextAttemptAt  DateTime?
  responseStatus Int?
  responseBody   String?               @db.Text
  errorMessage   String?
  createdAt      DateTime              @default(now())
  completedAt    DateTime?

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
  @@index([status, nextAttemptAt])
  @@index([eventId])
}

enum WebhookDeliveryStatus {
  PENDING
  RETRYING
  DELIVERED
  DEAD_LETTER
  CANCELED
}

// ---------------------------------------------------------------------------
// SSO — SAML + OIDC + SCIM (RFC 0004)
// ---------------------------------------------------------------------------
//
// One row = one IdP configuration scoped to a single Organization. We allow at
// most one SAML and one OIDC config per org (the @@unique below) since real-
// world enterprise customers run a single IdP at a time; multi-IdP is a
// follow-up RFC.
//
// Secrets-handling rules (mirror RFC 0002 / 0003):
//   - OIDC client secret → AES-256-GCM ciphertext, key HKDF-derived from
//     AUTH_SECRET + this row's id. Plaintext only flows through the
//     create / update server actions.
//   - SCIM token → sha256(plaintext) at rest; plaintext returned exactly once
//     at create or rotate. The 8-char prefix is safe to render in the UI.

model IdentityProvider {
  id       String      @id @default(cuid())
  orgId    String
  name     String // human-readable label, e.g. "Okta production"
  protocol SsoProtocol

  // ── SAML ─────────────────────────────────────────────────────────────
  // Full IdP metadata XML. saml-jackson parses out SSO URL, signing cert,
  // NameIDFormat, etc. Stored verbatim because metadata can also rotate
  // signing certs (multiple <KeyDescriptor> entries).
  samlMetadata String? @db.Text

  // ── OIDC ─────────────────────────────────────────────────────────────
  oidcIssuer       String?
  oidcClientId     String?
  oidcClientSecret Bytes?

  // ── Common ───────────────────────────────────────────────────────────
  emailDomains String[] @db.Text
  defaultRole  OrgRole  @default(MEMBER)

  // OWNER-only flag. When true, the org's members cannot use password / OAuth
  // login — they must come through this IdP. API tokens still work.
  enforceForLogin Boolean @default(false)

  // null → "configured but not yet live". A safety lane: OWNER can finish
  // the form, click "Test SSO" (RFC 0004 PR-2 dry-run), then flip enabledAt
  // to actually surface the entry on /login.
  enabledAt DateTime?

  // ── SCIM ─────────────────────────────────────────────────────────────
  scimTokenHash   String? @unique
  scimTokenPrefix String?
  scimEnabled     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  memberships  Membership[]

  // Hard-cap: 1 SAML + 1 OIDC per org. Reconfigure existing row to switch.
  @@unique([orgId, protocol])
  @@index([orgId])
}

enum SsoProtocol {
  SAML
  OIDC
}

model TwoFactorSecret {
  userId       String    @id
  encSecret    Bytes
  enabledAt    DateTime?
  backupHashes String[]  @db.Text
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// GDPR data export jobs (RFC 0002 PR-3)
// ---------------------------------------------------------------------------
//
// Async job table — a tiny worker (`scripts/run-export-jobs.ts`) claims a
// PENDING row, builds the zip via `src/lib/data-export/builder.ts`, uploads
// it via the storage abstraction (`src/lib/storage/`), and writes back the
// completion fields. We deliberately don't introduce a job-queue system at
// this stage — one cron + optimistic `updateMany` claim is enough for the
// expected volume (1 export / user / 24h).
//
// `scope = USER` ⇒ `orgId` is null and the actor (`userId`) is the export's
// owner. `scope = ORG` ⇒ `orgId` is set; ownership requires the actor to be
// OWNER of that org at trigger time.
//
// Storage layout: `storagePath` is interpreted by the active provider:
// LocalFsProvider treats it as a path under `DATA_EXPORT_STORAGE_DIR`,
// S3Provider treats it as an S3 key. Either way `expiresAt` is the wall-
// clock cutoff after which the file is purged + status flips to EXPIRED.

model DataExportJob {
  id           String           @id @default(cuid())
  userId       String // actor that triggered the job
  orgId        String? // null for USER scope, set for ORG scope
  scope        DataExportScope
  status       DataExportStatus @default(PENDING)
  storagePath  String?
  sizeBytes    Int?
  expiresAt    DateTime? // download URL valid until this point
  errorMessage String?
  createdAt    DateTime         @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  @@index([userId])
  @@index([orgId])
  @@index([status])
  @@index([expiresAt])
}

enum DataExportScope {
  USER
  ORG
}

enum DataExportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  EXPIRED
}

// ---------------------------------------------------------------------------
// Self-managed tokens — email verification & password reset
// ---------------------------------------------------------------------------
//
// We store only sha256(token); the raw token is delivered via email link.
// On consume we compare hashes and delete the row (single-use).

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expires    DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expires])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expires    DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expires])
}

// ---------------------------------------------------------------------------
// Billing — Stripe + Alipay + WeChat Pay subscriptions (RFC 0006 §6.1)
// ---------------------------------------------------------------------------
//
// Stripe path stays canonical: `provider = 'stripe'`, `stripeSubscriptionId`
// non-null. CN paths land in the same table with `provider in ('alipay',
// 'wechat')`, `cnAgreementId` non-null (= 支付宝免密协议号 / 微信周期扣款
// 合同号), and `stripeSubscriptionId` null. The new columns are nullable
// rather than synthesised so SQL queries reading "is this a Stripe sub?"
// stay readable.
//
// Invariants enforced application-side (Prisma can't express them):
//   1. provider = 'stripe' ⇒ stripeSubscriptionId NOT NULL ∧ cnAgreementId NULL
//   2. provider in ('alipay','wechat') ⇒ cnAgreementId NOT NULL ∧ stripeSubscriptionId NULL
//   3. The row's `region` (via Organization) determines which provider is
//      legal — Stripe in GLOBAL/EU, Alipay/WeChat in CN. The region-scoped
//      provider factory in `src/lib/region/providers.ts` is the only spot
//      that picks one; webhook routes refuse cross-provider events.

model Subscription {
  id                   String             @id @default(cuid())
  // PR-4 起 orgId 是唯一所有者；userId 已删除（保留在 git 历史里）。
  orgId                String
  // RFC 0006 — which payment rail issued this subscription. Stamped at
  // creation from the active billing provider; immutable thereafter.
  provider             String             @default("stripe")
  // Non-null for `provider = 'stripe'`. Nullable since RFC 0006 to make
  // room for CN subscriptions that carry no Stripe ID.
  stripeSubscriptionId String?            @unique
  // RFC 0006 — Alipay / WeChat 周期扣款的合同号（i.e. the merchant-side
  // identifier returned by `alipay.user.agreement.page.sign` or by the
  // WeChat Pay Native sign endpoint). Stripe path leaves this null.
  cnAgreementId        String?            @unique
  stripePriceId        String
  status               SubscriptionStatus
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
  @@index([provider])
  // cnAgreementId already gets a btree from `@unique` above; no extra
  // @@index needed.
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

// ---------------------------------------------------------------------------
// Stripe webhook idempotency — "have we processed this event id before?"
// ---------------------------------------------------------------------------

model StripeEvent {
  id          String   @id // Stripe's event id, e.g. "evt_..."
  type        String
  processedAt DateTime @default(now())

  @@index([type])
  @@index([processedAt])
}

// ---------------------------------------------------------------------------
// CN billing webhook idempotency (RFC 0006 §6.2) — Alipay + WeChat Pay
// ---------------------------------------------------------------------------
//
// Stripe events keep using `StripeEvent` (UI / admin pages depend on its
// shape — see `/admin/stripe-events`); we deliberately do NOT consolidate
// the two tables in this PR. New table covers Alipay + WeChat only,
// keyed by `(provider, providerEventId)` so the two SDKs' overlapping id
// namespaces stay separated.
//
// `payload` keeps the verified-and-decrypted notification body so the
// webhook handler stays idempotent on retry: a duplicate POST short-
// circuits at the unique constraint and we re-respond 200 without
// touching the Subscription. Useful for forensics / replays too.

model BillingEvent {
  id              String   @id @default(cuid())
  // 'alipay' | 'wechat'
  provider        String
  // Provider-side event id (Alipay 的 `out_trade_no` 或通知里的 `notify_id`
  // / WeChat 的 `event_id`). Whichever id the SDK gives us per-event.
  providerEventId String
  // Verbatim event type — `trade.success` / `trade.refund` / `agreement.signed`
  // / `transaction.success` etc. Free-form on purpose; routing reads this.
  type            String
  processedAt     DateTime @default(now())
  payload         Json?

  @@unique([provider, providerEventId])
  @@index([provider, processedAt])
  @@index([type])
}

// ---------------------------------------------------------------------------
// Personal API tokens — per-user bearer credentials for the public API
// ---------------------------------------------------------------------------
//
// We persist sha256(token); the raw token is shown to the user exactly once
// at creation. `prefix` is the first ~8 chars so users can identify rows
// later without the full secret.

model ApiToken {
  id         String    @id @default(cuid())
  // userId 永久保留作为「token 归属人」（谁创建的）；orgId 决定 scope。
  // 一对一绑定 org，跨 org 不允许（RFC-0001 §9 决策）。
  userId     String
  orgId      String
  name       String
  tokenHash  String    @unique
  prefix     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
}

// ---------------------------------------------------------------------------
// Audit log — append-only operational journal
// ---------------------------------------------------------------------------
//
// Records sensitive actions (role changes, password change, account deletion,
// sign-out-everywhere, future billing ops). Read-only via the admin UI.
// `actorId` may reference a deleted user — keep it nullable, no FK so the row
// survives the actor's deletion.

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  // 与 actorId 同样不加外键 —— org 删除后审计行需要保留（append-only）。
  // 全局动作（平台 admin 改其它用户角色等）允许 orgId 为 null。
  orgId     String?
  action    String
  target    String?
  metadata  Json?
  ip        String?
  // RFC 0005 — region the row was written from. Stamped automatically by
  // `recordAudit()` from `currentRegion()`; never accepted as input. The
  // `(region, createdAt)` composite below is the index compliance reports
  // hit ("CN audit rows in window X") so it leads with region.
  region    Region   @default(GLOBAL)
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([orgId])
  @@index([action])
  @@index([createdAt])
  @@index([region, createdAt])
}
