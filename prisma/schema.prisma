// Prisma schema for Kitora
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Uncomment when deploying behind a connection pooler (Supabase / Neon /
  // Vercel Postgres) — `url` then points at the pooled connection, while
  // `directUrl` is used by `prisma migrate` and introspection.
  // directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth) — required tables
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // for credentials provider
  role          UserRole  @default(USER)
  locale        String    @default("en")
  // Bumped whenever the user wants to invalidate every issued JWT (password
  // change, "sign out everywhere", account deletion). Compared inside the
  // jwt callback — mismatch forces the holder to sign in again.
  sessionVersion Int      @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  apiTokens   ApiToken[]
  memberships Membership[]

  @@index([email])
}

enum UserRole {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// Organizations — 多租户主体（参见 docs/rfcs/0001-organizations.md）
// ---------------------------------------------------------------------------
//
// 每个用户注册自动创建一个 Personal Org（slug = personal-{shortId}），用户
// 为 OWNER。所有 org-scoped 资源（Subscription / ApiToken / AuditLog）以
// orgId 归属。PR-1 仅引入新表与 nullable orgId 列，旧字段保留以便回滚。

model Organization {
  id               String   @id @default(cuid())
  slug             String   @unique // URL-safe lowercase, e.g. "acme" / "personal-abcd1234"
  name             String
  image            String?
  // Stripe customer 归属在 Org 上 —— PR-4 后这是唯一来源
  stripeCustomerId String?  @unique
  // RFC 0005 占位字段：per-org ICP 备案号；PR-1 仅加列，业务逻辑后续 RFC 实现
  icpNumber        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships   Membership[]
  invitations   Invitation[]
  subscriptions Subscription[]
  apiTokens     ApiToken[]

  @@index([slug])
}

model Membership {
  id       String   @id @default(cuid())
  orgId    String
  userId   String
  role     OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// 邀请：raw token 随邮件发出，库内只存 sha256(token)。同一 org + email
// 仅允许一条 pending 记录（接受 / 撤销后该约束不再阻止重新邀请，因为
// acceptedAt / revokedAt 标记会与 unique 上的过滤一起在应用层处理）。

model Invitation {
  id         String    @id @default(cuid())
  orgId      String
  email      String
  role       OrgRole
  tokenHash  String    @unique
  expiresAt  DateTime
  // 邀请人 userId — no FK，邀请人删号也保留这条记录用于审计
  invitedBy  String
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([email])
  @@index([expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Self-managed tokens — email verification & password reset
// ---------------------------------------------------------------------------
//
// We store only sha256(token); the raw token is delivered via email link.
// On consume we compare hashes and delete the row (single-use).

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expires    DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expires])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expires    DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expires])
}

// ---------------------------------------------------------------------------
// Billing — Stripe subscriptions
// ---------------------------------------------------------------------------

model Subscription {
  id                   String             @id @default(cuid())
  // PR-4 起 orgId 是唯一所有者；userId 已删除（保留在 git 历史里）。
  orgId                String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

// ---------------------------------------------------------------------------
// Stripe webhook idempotency — "have we processed this event id before?"
// ---------------------------------------------------------------------------

model StripeEvent {
  id          String   @id // Stripe's event id, e.g. "evt_..."
  type        String
  processedAt DateTime @default(now())

  @@index([type])
  @@index([processedAt])
}

// ---------------------------------------------------------------------------
// Personal API tokens — per-user bearer credentials for the public API
// ---------------------------------------------------------------------------
//
// We persist sha256(token); the raw token is shown to the user exactly once
// at creation. `prefix` is the first ~8 chars so users can identify rows
// later without the full secret.

model ApiToken {
  id         String    @id @default(cuid())
  // userId 永久保留作为「token 归属人」（谁创建的）；orgId 决定 scope。
  // 一对一绑定 org，跨 org 不允许（RFC-0001 §9 决策）。
  userId     String
  orgId      String
  name       String
  tokenHash  String    @unique
  prefix     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
}

// ---------------------------------------------------------------------------
// Audit log — append-only operational journal
// ---------------------------------------------------------------------------
//
// Records sensitive actions (role changes, password change, account deletion,
// sign-out-everywhere, future billing ops). Read-only via the admin UI.
// `actorId` may reference a deleted user — keep it nullable, no FK so the row
// survives the actor's deletion.

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  // 与 actorId 同样不加外键 —— org 删除后审计行需要保留（append-only）。
  // 全局动作（平台 admin 改其它用户角色等）允许 orgId 为 null。
  orgId     String?
  action    String
  target    String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([orgId])
  @@index([action])
  @@index([createdAt])
}
