# ============================================================================
# Kitora · 本地默认环境变量（committed to git）
# ----------------------------------------------------------------------------
# 这里只放 *非秘密* 默认值。任何真 secret —— Auth.js / Stripe / Resend / OAuth
# client secret / 生产数据库密码等 —— 必须放到 .env.local（已 gitignored）
# 或者部署平台（Vercel / Fly / Railway）的环境变量面板里。
# ----------------------------------------------------------------------------
# Next.js 加载顺序：.env.*.local > .env.local > .env.{development|production}
# > .env，所以 .env.local 中同名变量会自动覆盖这里的占位值。
# ============================================================================

# --- 应用 -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kitora"

# --- 数据库（本地 docker compose 起的 postgres，仅本机可达，非生产连接串）---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kitora?schema=public"

# --- Auth.js (NextAuth v5) --------------------------------------------------
# ⚠️ 这是占位值，仅用于让 dev / build 通过 zod 校验（>= 32 字节）。
# 生产部署前必须在 .env.local 或平台 secret 中覆盖一个真值：
#   openssl rand -base64 32
AUTH_SECRET="dev-only-not-secure-please-override-with-openssl-rand"

# --- 日志 -------------------------------------------------------------------
LOG_LEVEL="info"

# --- 邮件（默认发件人，非 secret；RESEND_API_KEY 必须放 .env.local）---------
EMAIL_FROM="Kitora <onboarding@example.com>"

# ============================================================================
# 下列变量留空即生效"未配置 = noop"模式，需要时在 .env.local 里补：
#
#   AUTH_GITHUB_ID / AUTH_GITHUB_SECRET            # GitHub OAuth
#   AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET            # Google OAuth
#   STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET      # 计费
#   STRIPE_PRO_PRICE_ID / STRIPE_TEAM_PRICE_ID
#   RESEND_API_KEY                                 # 事务邮件
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN  # 限流
#   NEXT_PUBLIC_ANALYTICS_ID                       # 埋点
#   DIRECT_URL                                     # 池化部署的直连 URL
# ============================================================================
